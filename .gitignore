# ==========================================
# Ambientes Virtuais (Virtualenvs)
# ==========================================
venv/
.venv/
env/
ENV/

# ==========================================
# Variáveis de Ambiente (Segurança)
# ==========================================
.env
.env.*

# ==========================================
# Cache do Python e Arquivos Compilados
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# Configurações de IDEs e Editores
# ==========================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# Arquivos do Sistema Operacional
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Logs e Bancos Locais (Caso use SQLite no futuro)
# ==========================================
*.log
*.sqlite3
*.db